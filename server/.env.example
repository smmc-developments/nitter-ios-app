# Use a long random value and configure the same value in the iOS app.
API_KEY=replace-with-a-random-secret

# Optional separate signing key for media URLs. Keep this stable across deploys.
# When omitted, API_KEY is used; without either value, a key is persisted in DATA_DIR.
PROXY_SECRET=

# Set to true only for an isolated local test environment.
ALLOW_INSECURE_NO_AUTH=false

FETCH_MINUTES=15

# Automatic cycles fetch at most this many due accounts. Manual fetches still fetch all.
MAX_ACCOUNTS_PER_CYCLE=40

# Conservative defaults: two in-flight requests, starts spaced one second apart.
FETCH_CONCURRENCY=2
FETCH_START_INTERVAL_MS=1000

# Follow Nitter cursors to catch bursts and gradually backfill older posts.
MAX_PAGES_PER_ACCOUNT=5

# Include account replies in addition to posts and reposts.
INCLUDE_REPLIES=true

# Maximum reply conversation pages fetched for parent context per cycle.
MAX_PARENT_ENRICHMENTS=20
